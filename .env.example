# Copy this file to .env and fill in your values.
# Only needed for Capacitor (native mobile) builds.
# The web build uses the Vite proxy and does not need this.

# IP/hostname of the machine running the FastAPI backend on your local network.
# Example: VITE_BACKEND_URL=http://192.168.1.10:8000
VITE_BACKEND_URL=http://192.168.1.10:8000
